# Dependencies
node_modules/
.npm-cache/
# Build output
dist/

# Local config (installation-specific, not committed)
.gitleaks-local.toml

# Local data & auth
store/
data/
logs/

# Groups - only track base structure and specific CLAUDE.md files
groups/*
!groups/main/
!groups/global/
groups/main/*
groups/global/*
!groups/main/CLAUDE.md
!groups/global/CLAUDE.md

# Secrets
*.keys.json
.env

# MCP servers
mcp-servers/
**/mcp-servers/

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system — ignore all by default (copied from other repos per-install),
# then whitelist skills that are part of this repo.
.nanoclaw/
container/skills/*
!container/skills/agent-browser/

agents-sdk-docs
