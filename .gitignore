# Dependencies
node_modules/
.npm-cache/
# pnpm content-addressable store (created when running in sandbox mode)
.pnpm-store/
# Build output
dist/

# Local data & auth
store/
# data/* (not data/) so the `!` exception lines below can re-include
# specific files. A `data/` rule excludes the whole directory which
# blocks any per-file re-include.
data/*
# Narrow exceptions — committed config schema templates only.
# NEVER widen to a glob (e.g. !data/*.example) — gitignored data/ can
# contain secrets / installation-specific names; explicit per-file
# allowlist keeps the blast radius small. See K.1.f step 11 risk-pass.
!data/backend-defaults.json.example
!data/mcp-servers.json.example
logs/

# Groups - per-installation state, not tracked
groups/*

# Composer-managed CLAUDE.md artifacts (regenerated every spawn) and
# per-group memory (CLAUDE.local.md) must never be committed.
**/CLAUDE.local.md
**/.claude-shared.md
**/.claude-fragments/

# Secrets
*.keys.json
.env
.env*

# Temp files
.tmp-*

# OS
.DS_Store

# IDE
.idea/
.vscode/

# Skills system (local per-installation state)
.nanoclaw/

agents-sdk-docs

# v1-to-v2 migration run reports (per-run artifacts, not source).
scripts/v1-migration-reports/
